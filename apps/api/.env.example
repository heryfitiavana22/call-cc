NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# LLM — required
OPENAI_API_KEY=sk-...

# Language — BCP-47 code used in STT, LLM system prompt, and TTS (default: fr)
# Set to "multi" for Deepgram multilingual mode (STT only)
AGENT_LANGUAGE=fr

# Tools (each key enables the corresponding tool — omit to disable)
# TAVILY_API_KEY=tvly-...   # enables web_search

# ─── STT — choose one provider (default: groq) ────────────────────────────────

## Fast batch transcription via Whisper (whisper-large-v3-turbo)
STT_PROVIDER=groq
GROQ_API_KEY=...

## Real-time WebSocket streaming
# STT_PROVIDER=deepgram
# DEEPGRAM_API_KEY=...

## Not yet implemented
# STT_PROVIDER=openai

# ─── TTS — choose one provider (default: openai) ──────────────────────────────

## Uses OPENAI_API_KEY above, no extra key needed
# TTS_PROVIDER=openai

## ~40ms TTFA, supports emotion/speed/volume (sonic-3)
## Voice IDs: https://play.cartesia.ai/voices
# TTS_PROVIDER=cartesia
# CARTESIA_API_KEY=...
# CARTESIA_VOICE_ID=...

## ~75ms, ultra-low latency model (eleven_flash_v2_5)
## Voice IDs: https://elevenlabs.io/voice-library
# TTS_PROVIDER=elevenlabs
# ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=...
