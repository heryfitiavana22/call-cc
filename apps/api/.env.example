NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# LLM
OPENAI_API_KEY=sk-...

# STT — set one key to activate that provider (priority: Deepgram > Groq > OpenAI Whisper)
DEEPGRAM_API_KEY=...
# GROQ_API_KEY=...
AGENT_LANGUAGE=fr

# Tools (each key enables the corresponding tool — omit to disable)
# TAVILY_API_KEY=tvly-...   # enables web_search

# TTS — choose one provider (default: openai)
# TTS_PROVIDER=openai       # uses OPENAI_API_KEY above, no extra key needed

## Voice IDs: https://play.cartesia.ai/voices
## ~40ms TTFA, supports emotion/speed/volume (sonic-3)
# TTS_PROVIDER=cartesia                          
# CARTESIA_API_KEY=...
# CARTESIA_VOICE_ID=...

## Voice IDs: https://elevenlabs.io/voice-library
## ~75ms, ultra-low latency model (eleven_flash_v2_5)
# TTS_PROVIDER=elevenlabs                
# ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=...
