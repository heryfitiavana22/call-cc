{
  "name": "@call-cc/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:integration": "tsx --env-file=.env node_modules/vitest/vitest.mjs run --reporter=verbose src/infrastructure"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@call-cc/types": "workspace:*",
    "@cartesia/cartesia-js": "^3.0.0",
    "@deepgram/sdk": "^5.0.0",
    "@elevenlabs/elevenlabs-js": "^2.43.0",
    "@hono/node-server": "^1.14.1",
    "@hono/node-ws": "^1.3.0",
    "@tavily/core": "^0.7.2",
    "ai": "^6.0.161",
    "groq-sdk": "^1.1.2",
    "hono": "^4.7.11",
    "openai": "^6.34.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@call-cc/eslint-config": "workspace:*",
    "@call-cc/tsconfig": "workspace:*",
    "@types/node": "^25.6.0",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
